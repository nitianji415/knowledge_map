# ====================================================================
# AI 知识地图 - 配置文件
#
# 两种部署方式:
#   1. docker compose up -d              ← 推荐,无需装 Python/Node/PG
#      只需填下面的【LLM API Key】区域,网络配置 docker-compose 会自动覆盖
#   2. 直接 python3 server.py             ← 开发模式
#      所有变量都生效,需要本地装好 Postgres + Node + open-webSearch
# ====================================================================


# ========== 0. 认证 / 加密 (生产部署务必改) ==========
# 首次启动:用 ADMIN_USERNAME/ADMIN_PASSWORD 建账号。密码登录后请去设置页改。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT 签名 secret 和 API key 加密 secret —— 生产环境务必各换成 32 字以上随机字符串
# 改 SETTINGS_SECRET 后 DB 里加密的旧 LLM key 就解不出来了,必须重新填
JWT_SECRET=knowledge-map-dev-jwt-secret-please-change
SETTINGS_SECRET=knowledge-map-dev-settings-secret-please-change
JWT_EXPIRES_HOURS=336

# 关掉 auth 仅供 pytest 自动化,生产严禁
# AUTH_ENABLED=true


# ========== 1. LLM (OpenAI 兼容协议,必填) ==========
# 全系统走单一 OpenAI Chat Completions 协议。
# DeepSeek / Moonshot / OpenRouter / 自建 vLLM 等任何 OpenAI 兼容服务,改 base_url 就能换。

# API Key —— DeepSeek 在 https://platform.deepseek.com 申请
LLM_API_KEY=

# 模型名 —— 默认 deepseek-chat (V3 通用)。也可填 deepseek-reasoner、moonshot-v1-8k 等
LLM_MODEL=deepseek-chat

# API 入口 —— OpenAI SDK 会自动拼接 /chat/completions,所以只写到 /v1
LLM_BASE_URL=https://api.deepseek.com/v1


# ========== 2. 网页搜索 (Docker 部署可不改) ==========

# 搜索路由: open=本地免费 daemon | anysearch=AnySearch 聚合 | off=禁用
SEARCH_PROVIDER=open

# 本地 open-webSearch daemon
# - Docker 部署:URL 由 compose 自动设为 http://open-websearch:3210
# - 直接 python 启动:留默认值,主 app 会自动 spawn 子进程
OPEN_WEBSEARCH_URL=http://127.0.0.1:3210
OPEN_WEBSEARCH_ENGINES=sogou,duckduckgo
OPEN_WEBSEARCH_SEARCH_MODE=auto
OPEN_WEBSEARCH_LIMIT=8
OPEN_WEBSEARCH_TIMEOUT=20.0
OPEN_WEBSEARCH_AUTOSTART=true
OPEN_WEBSEARCH_DIR=external/open-webSearch
OPEN_WEBSEARCH_NODE_BIN=node

# AnySearch (https://api.anysearch.com) ── SEARCH_PROVIDER=anysearch 时生效
# api_key 留空 = 匿名按 IP 限免费额度;填了 = Bearer 认证、更高并发 + 付费额度
# 也可以登录后从设置页改,DB 优先于 .env
ANYSEARCH_API_KEY=
ANYSEARCH_BASE_URL=https://api.anysearch.com
ANYSEARCH_LIMIT=10
ANYSEARCH_TIMEOUT=20.0
# 每条结果喂给 AI 的正文字符上限。加大 → AI 看到的更多 → 回答更深;
# 但 prompt 成本翻倍。主流 128K 模型完全装得下 3000-5000。
ANYSEARCH_CONTENT_LIMIT=2000
# 留空让 AnySearch 自动判断;填 cn / intl 强制走对应区域
ANYSEARCH_ZONE=
# 留空 = 不显式传;典型 zh-CN / en
ANYSEARCH_LANGUAGE=


# ========== 3. 高级:网络 / 数据库 / 模型参数 ==========
# Docker 部署下,host/port/database_url 都被 docker-compose 强制覆盖。
# 只有直接 python3 server.py 跑时才生效。

KNOWLEDGE_MAP_HOST=127.0.0.1
KNOWLEDGE_MAP_PORT=8765

# 默认 Postgres。本地速跑可切 SQLite:
#   DATABASE_URL=sqlite+aiosqlite:///./data/knowledge_map.sqlite3
DATABASE_URL=postgresql+asyncpg://knowledge_map:knowledge_map@127.0.0.1:5432/knowledge_map

# 单次回答输出长度上限。Zen 长答案需要 8K 余量。
LLM_MAX_TOKENS=8192
LLM_LOG_RESPONSES=true
LLM_LOG_MAX_CHARS=4000

# 仅供测试,默认走 SQLite in-memory
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:
